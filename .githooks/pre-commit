#!/bin/bash

# Pre-commit hook for HyperSonicAnalyzer
# Runs clang-format and clang-tidy on staged C++ files

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get the list of staged C++ files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|h|hpp)$' || true)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}No C++ files staged, skipping checks.${NC}"
    exit 0
fi

echo -e "${YELLOW}Running pre-commit checks on staged C++ files...${NC}"

# Check if clang-format is available
if command -v clang-format &> /dev/null; then
    echo -e "${YELLOW}Running clang-format...${NC}"
    
    FORMAT_FAILED=0
    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            # Check if file needs formatting
            if ! clang-format --dry-run --Werror "$file" 2>/dev/null; then
                echo -e "${RED}Formatting issue in: $file${NC}"
                # Auto-fix the formatting
                clang-format -i "$file"
                git add "$file"
                echo -e "${GREEN}Auto-formatted and re-staged: $file${NC}"
            fi
        fi
    done
else
    echo -e "${YELLOW}clang-format not found, skipping format check.${NC}"
fi

# Check if clang-tidy is available and compile_commands.json exists
if command -v clang-tidy &> /dev/null; then
    if [ -f "build/compile_commands.json" ]; then
        echo -e "${YELLOW}Running clang-tidy...${NC}"
        
        TIDY_FAILED=0
        for file in $STAGED_FILES; do
            if [ -f "$file" ]; then
                # Run clang-tidy (warnings only, don't fail the commit)
                clang-tidy -p build "$file" 2>/dev/null || true
            fi
        done
    else
        echo -e "${YELLOW}compile_commands.json not found, skipping clang-tidy.${NC}"
        echo -e "${YELLOW}Run 'cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON ..' in build/ to enable.${NC}"
    fi
else
    echo -e "${YELLOW}clang-tidy not found, skipping lint check.${NC}"
fi

echo -e "${GREEN}Pre-commit checks completed.${NC}"
exit 0
